# ============================================================
#  LUX Driver — Variáveis de Ambiente
#  COMO USAR:
#    1. Copie este arquivo: cp .env.example .env
#    2. Preencha os valores reais no .env
#    3. NUNCA commite o .env no Git (já está no .gitignore)
# ============================================================

# ─────────────────────────────────────────────
# VERCEL
# ─────────────────────────────────────────────
# Token de autenticação do Vercel CLI
# Obter em: https://vercel.com/account/tokens
VERCEL_TOKEN=seu_token_vercel_aqui

# ID do projeto no Vercel (opcional, para CI/CD)
# Obter em: Vercel Dashboard → Project → Settings → General
VERCEL_PROJECT_ID=

# ID da organização/conta no Vercel (opcional)
VERCEL_ORG_ID=

# ─────────────────────────────────────────────
# PUSHINPAY (Pagamentos PIX)
# ─────────────────────────────────────────────
# Token da API PushinPay
# Obter em: https://pushinpay.com.br → Configurações → API
PUSHINPAY_TOKEN=seu_token_pushinpay_aqui

# Webhook secret para validar requisições
PUSHINPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# BLACKBOX AI (API Credits)
# ─────────────────────────────────────────────
# Token da API Blackbox (créditos API $49,99)
# Obter em: https://www.blackbox.ai → Account → API Keys
BLACKBOX_API_KEY=seu_token_blackbox_aqui

# ─────────────────────────────────────────────
# CONFIGURAÇÕES DO APP
# ─────────────────────────────────────────────
# URL base do app em produção
VITE_APP_URL=https://lux-driver-assistent-18y8.vercel.app

# Ambiente (development | production)
VITE_ENV=development

# ─────────────────────────────────────────────
# ANDROID / CAPACITOR
# ─────────────────────────────────────────────
# Caminho do Android SDK (se não estiver no PATH)
# ANDROID_HOME=C:\Users\SAULO\AppData\Local\Android\Sdk

# Alias do keystore para assinar o APK
# KEYSTORE_ALIAS=lux-release
# KEYSTORE_FILE=android/app/lux-release.jks
# KEYSTORE_PASSWORD=sua_senha_aqui
